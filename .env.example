# Copy to `.env` and fill in.

# ---------------------------------------------------------------------------
# DATABASE — Neon Postgres. Two URLs, and they are NOT interchangeable.
# ---------------------------------------------------------------------------
# POOLED endpoint (note "-pooler" in the host). The APP uses this. Serverless opens a
# connection per cold start and Postgres caps them hard — without the pooler in front,
# a traffic spike exhausts connections and every request starts failing.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# DIRECT endpoint (no "-pooler"). The Prisma CLI uses this for `db push` / `migrate` / `seed`,
# because a transaction pooler cannot run DDL.
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ---------------------------------------------------------------------------
# AUTH
# ---------------------------------------------------------------------------
# Signs the session JWT. Generate a real one before deploying:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me"

# Absolute site URL. Used by sitemap.xml, robots.txt and the OpenGraph card.
# If unset it falls back to http://localhost:3000 — which means a deployed site would
# advertise localhost URLs to Google. Always set this in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# OTP LOGIN — pick exactly ONE of the three options below
# ---------------------------------------------------------------------------

# OPTION 1 — LOCAL DEV. Skips SMS entirely and accepts 123456 as the code for any phone.
# MUST be "false" in production, or anyone who finds the URL can log in as admin.
DEV_OTP_BYPASS="true"

# OPTION 2 — REAL SMS (the production answer). BD bulk-SMS gateways (BulkSMSBD, SSL Wireless,
# Alpha Net, Reve) all take a form-encoded POST with an api key, sender id and 8801XXXXXXXXX
# number. Set all three and real codes start going out. See sendOtpSms() in src/lib/otp.ts.
# SMS_API_URL="https://bulksmsbd.net/api/smsapi"
# SMS_API_KEY=""
# SMS_SENDER_ID=""

# OPTION 3 — SECRET DEMO CODE. For a deployed demo with no SMS gateway yet: set this to a
# secret 6-digit value and it becomes the OTP for every phone. It is never shown in the UI and
# never logged, and it is rate-limited like a real code (5 wrong guesses burns it).
# It is effectively a SHARED PASSWORD — anyone who learns it can sign in as admin.
# Remove it the moment a real SMS gateway is configured.
# DEMO_ACCESS_CODE=""
