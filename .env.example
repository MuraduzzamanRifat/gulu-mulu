# Copy to `.env` and fill in.
#
# Local dev uses SQLite — no Docker or Postgres install required.
# To move to Postgres: set a postgresql:// URL here, change the provider in
# prisma/schema.prisma, and swap the adapter in src/lib/db.ts (@prisma/adapter-pg).
DATABASE_URL="file:./prisma/dev.db"

# Signs the session JWT. Generate a real one before deploying:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me"

# When "true", skips real SMS and accepts 123456 as the OTP for any phone.
# MUST be "false" in production, with an SMS gateway wired up.
DEV_OTP_BYPASS="true"
